package in.btm.service;

import java.util.List;

import org.springframework.stereotype.Service;

import in.btm.dto.AddressDto;
import in.btm.entity.Address;
import in.btm.entity.UserProfile;
import in.btm.exception.AddressNotFoundException;
import in.btm.exception.UnauthorizedAddressAccessException;
import in.btm.exception.UserNotFoundException;
import in.btm.mapper.AddressMapper;
import in.btm.repository.AddressRepository;
import in.btm.repository.UserRepository;
import jakarta.transaction.Transactional;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
@Transactional
public class AddressServiceImpl implements AddressService {

	private final AddressRepository addressRepository;
	private final UserRepository userRepository;
	private final AddressMapper addressMapper;

	@Override
	@Transactional
	public AddressDto addAddress(String username, AddressDto dto) {

		UserProfile user = getUserByUsername(username);

		Address address = addressMapper.toEntity(dto);
		address.setUser(user);

		return addressMapper.toDto(addressRepository.save(address));
	}

	@Override
	public List<AddressDto> getMyAddresses(String username) {

		UserProfile user = getUserByUsername(username);

		return user.getAddresses().stream().map(addressMapper::toDto).toList();
	}

	@Override
	public AddressDto updateAddress(Integer addressId, AddressDto dto, String username) {

		Address address = getAddressById(addressId);

		validateOwnership(address, username);

		addressMapper.updateEntityFromDto(dto, address);

		return addressMapper.toDto(addressRepository.save(address));
	}

	@Override
	public void deleteAddress(Integer addressId, String username) {

		Address address = getAddressById(addressId);

		validateOwnership(address, username);

		addressRepository.delete(address);
	}

	private UserProfile getUserByUsername(String username) {

		return userRepository.findByEmail(username)
				.orElseThrow(() -> new UserNotFoundException("User not found: " + username));
	}

	private Address getAddressById(Integer addressId) {

		return addressRepository.findById(addressId)
				.orElseThrow(() -> new AddressNotFoundException("Address not found with id: " + addressId));
	}

	private void validateOwnership(Address address, String username) {

		if (!address.getUser().getEmail().equals(username)) {

			throw new UnauthorizedAddressAccessException("You are not authorized to access this address");
		}
	}
}