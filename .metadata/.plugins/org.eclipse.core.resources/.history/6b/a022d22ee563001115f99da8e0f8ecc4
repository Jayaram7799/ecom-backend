package in.btm.service;



import in.btm.dto.ActivateAccountRequest;
import in.btm.dto.AuthResponse;
import in.btm.dto.ForgotPasswordRequest;
import in.btm.dto.LoginRequestDto;
import in.btm.dto.RegisterRequest;

public interface AuthService {

    /**
     * Register a new user.
     * Creates INACTIVE account and sends temporary password.
     */
    void register(RegisterRequest request);

    /**
     * Activate account using temporary password.
     */
    void activate(ActivateAccountRequest request);

    /**
     * Login active user.
     */
    AuthResponse login(LoginRequestDto request);

    /**
     * Generate and send a new temporary password.
     */
    void forgotPassword(ForgotPasswordRequest request);

    /**
     * Check whether email exists.
     */
    boolean isEmailExists(String email);
}